{
 "name": "@packages/core",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./exceptions/*": {
      "types": "./dist/exceptions/*.d.ts",
      "default": "./dist/exceptions/*.js"
